{
  "name": "expressedrealms.client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "npx vite",
    "build": "npx run-p \"build-only {@}\" --",
    "preview": "npx vite preview",
    "build-only": "npx vite build",
    "type-check": "npx vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "lint": "npx eslint . --fix",
    "linters": "npx eslint . --fix",
    "component-tests": "sudo chown -hR $(whoami) node_modules/; npx cypress run --component --browser chrome",
    "open-cypress": "sudo chown -hR $(whoami) node_modules/; npx cypress open",
    "vitest": "sudo chown -hR $(whoami) node_modules/; npx vitest --run",
    "vitest-pipeline": "npx vitest --coverage"
  },
  "dependencies": {
    "@he-tree/vue": "^2.10.5",
    "@pinia/colada": "^1.3.1",
    "@pinia/colada-plugin-delay": "^0.2.1",
    "@primeuix/themes": "^2.0.3",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-underline": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@tiptap/vue-3": "^3.23.6",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "axios": "^1.16.1",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "date-fns": "^4.3.0",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "md5": "^2.3.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "qrcode": "^1.5.4",
    "quill": "^2.0.3",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.34",
    "vue-easy-dnd": "^2.2.2",
    "vue-qrcode-reader": "^5.7.3",
    "vue-router": "^5.0.7",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@pinia/colada-devtools": "^1.0.0",
    "@rushstack/eslint-patch": "^1.16.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node18": "^18.2.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "cross-fetch": "^4.1.0",
    "cypress": "^15.15.0",
    "cypress-multi-reporters": "^2.0.5",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-plugin-cypress": "^5.1.0",
    "eslint-plugin-sonarjs": "^3.0.4",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jest-matchmedia-mock": "^1.1.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "mocha-junit-reporter": "^2.2.1",
    "npm-run-all2": "^9.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.100.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
